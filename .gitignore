# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
*.egg
venv/
.venv/
env/

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/profiles.yml

# Airflow
airflow/logs/
airflow/*.pid
airflow/airflow.db

# Great Expectations
great_expectations/uncommitted/

# Snowflake credentials
*.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Terraform
terraform/.terraform/
terraform/*.tfstate*
terraform/*.tfvars

# Power BI (large binary)
dashboards/powerbi/*.pbix

# Secrets - NEVER commit
**/secrets/
**/credentials/
**/tokens/
profiles.yml

# Office temp files
~$*

# Jupyter checkpoints
.ipynb_checkpoints/

# Personal documents (keep in separate folder, not in repo)
*.docx
*.xlsx
*.pptx

# Local data zone — keep small Gold demo CSVs (dashboard needs them),
# ignore bulk landing files + any generated Parquet
data/landing/
data/raw/
data/**/*.parquet

# Claude Code local tooling (dev preview config)
.claude/
